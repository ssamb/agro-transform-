generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String                  @id @default(uuid())
  email           String                  @unique
  password        String
  nom             String
  role            Role                    @default(TRANSFORMATEUR)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  recettes        RecetteTransformation[]
  transformations Transformation[]

  @@map("users")
}

model MatierePremiere {
  id        String                  @id @default(uuid())
  nom       String
  categorie String
  unite     String
  stock     Float                   @default(0)
  stockMin  Float                   @default(0)
  stockMax  Float                   @default(0)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  recettes  RecetteTransformation[]

  @@map("matieres_premieres")
}

model ProduitFini {
  id        String                  @id @default(uuid())
  nom       String
  categorie String
  unite     String
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  recettes  RecetteTransformation[]

  @@map("produits_finis")
}

model RecetteTransformation {
  id                String           @id @default(uuid())
  nom               String
  description       String?
  rendementPercent  Float
  dureeTotale       Int?
  pertePercent      Float            @default(0)
  userId            String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  matierePremiereId String
  produitFiniId     String
  etapes            Etape[]
  matierePremiere   MatierePremiere  @relation(fields: [matierePremiereId], references: [id])
  produitFini       ProduitFini      @relation(fields: [produitFiniId], references: [id])
  user              User             @relation(fields: [userId], references: [id])
  transformations   Transformation[]

  @@map("recettes_transformation")
}

model Etape {
  id          String                @id @default(uuid())
  numero      Int
  description String
  duree       Int?
  recetteId   String
  recette     RecetteTransformation @relation(fields: [recetteId], references: [id], onDelete: Cascade)

  @@map("etapes")
}

model Transformation {
  id                String                @id @default(uuid())
  date              DateTime              @default(now())
  quantiteMP        Float
  quantitePF        Float
  perteReelle       Float                 @default(0)
  observations      String?
  userId            String
  recetteId         String
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  dateExpiration    DateTime?
  dateFabrication   DateTime?
  dureeConservation Int?
  pertePercent      Float                 @default(0)
  statut            String                @default("en_cours")
  recette           RecetteTransformation @relation(fields: [recetteId], references: [id])
  user              User                  @relation(fields: [userId], references: [id])

  @@map("transformations")
}

enum Role {
  ADMIN
  TRANSFORMATEUR
  FORMATEUR
  OBSERVATEUR
}
